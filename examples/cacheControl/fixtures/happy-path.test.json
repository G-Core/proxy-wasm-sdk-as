{
  "appType": "proxy-wasm",
  "description": "HTML response — sets public cache with must-revalidate and Vary header",
  "request": {
    "method": "GET",
    "url": "http://fastedge-builtin.debug",
    "headers": {
      "host": "example.com",
      "content-type": "text/html; charset=utf-8",
      "x-debugger-content": "body-only"
    },
    "body": "<html><body>Hello</body></html>"
  },
  "dotenv": {
    "enabled": true,
    "path": "."
  },
  "logLevel": 2,
  "wasm": {
    "path": "<workspace>/.fastedge-debug/app.wasm",
    "description": "Default debugger WASM binary"
  }
}
