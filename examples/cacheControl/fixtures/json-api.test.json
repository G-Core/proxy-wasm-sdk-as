{
  "appType": "proxy-wasm",
  "description": "JSON API response with API_MAX_AGE=0 — sets no-cache, no-store for API data",
  "request": {
    "method": "GET",
    "url": "http://fastedge-builtin.debug/api/data",
    "headers": {
      "host": "api.example.com",
      "content-type": "application/json",
      "x-debugger-content": "body-only"
    },
    "body": "{\"items\":[]}"
  },
  "dotenv": {
    "enabled": true,
    "path": "."
  },
  "logLevel": 2,
  "wasm": {
    "path": "<workspace>/.fastedge-debug/app.wasm",
    "description": "Default debugger WASM binary"
  }
}
